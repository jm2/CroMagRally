# Maintainer: John-Michael Mulesa <jmulesa@gmail.com>
#
# Official Arch artifact for Cro-Mag Rally. It builds and privately bundles the repository's
# pinned extern/SDL3 revision, matching every other official platform artifact.
#
# Built in CI for x86_64 only: the official archlinux Docker image has no arm64 variant.
pkgname=cromagrally
pkgver=3.1.1
pkgrel=1
pkgdesc="The wildest racing game since man invented the wheel!"
arch=('x86_64')
url="https://github.com/jm2/CroMagRally"
license=('CC-BY-NC-SA-4.0' 'MIT' 'LGPL-2.1-or-later' 'BSD-3-Clause'
	'BSL-1.0' 'CC0-1.0' 'Apache-2.0' 'Zlib' 'SunPro')
depends=('libglvnd' 'libx11' 'libxext' 'libxcursor' 'libxi' 'libxrandr'
	'libxfixes' 'libxss' 'libxkbcommon' 'wayland' 'libdecor' 'alsa-lib'
	'libpulse' 'pipewire' 'dbus' 'libdrm' 'mesa' 'liburing' 'libusb'
	'hicolor-icon-theme')
makedepends=('cmake' 'ninja' 'git')
options=('!lto' '!debug') # !lto keeps FP behavior predictable (pairs with -ffp-contract=off);
                          # !debug stops makepkg emitting a second cromagrally-debug package
                          # (two .pkg.tar.zst would break the single-file copy in CI)
source=()                 # built in-tree from $startdir; submodules must already be populated

pkgver() {
	sed -n 's/^GAME_VERSION=//p' "$startdir/version.properties"
}

build() {
	cd "$startdir"
	cmake -S . -B build-arch -G Ninja \
		-DCMAKE_BUILD_TYPE=RelWithDebInfo \
		-DCMR_INSTALL=ON \
		-DBUILD_SDL_FROM_SOURCE=ON \
		-DCMR_BUNDLE_SDL=ON \
		-DCMAKE_INSTALL_PREFIX=/usr
	cmake --build build-arch
}

package() {
	cd "$startdir"
	# CMR_INSTALL places the game and dependency licenses under
	# /usr/share/licenses/cromagrally.
	DESTDIR="$pkgdir" cmake --install build-arch
}
